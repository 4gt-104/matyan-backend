FROM python:3.12-slim AS base

ARG IMAGE_VERSION=0.2.0
LABEL org.opencontainers.image.title="matyan-backend"
LABEL org.opencontainers.image.description="Production-ready experiment tracker"
LABEL org.opencontainers.image.version="${IMAGE_VERSION}"
LABEL org.opencontainers.image.source="https://github.com/4gt-104/matyan-core"
LABEL org.opencontainers.image.documentation="https://4gt-104.github.io/matyan-core/"
LABEL org.opencontainers.image.licenses="Apache-2.0"

COPY --from=ghcr.io/astral-sh/uv:0.10.3@sha256:7a88d4c4e6f44200575000638453a5a381db0ae31ad5c3a51b14f8687c9d93a3 /uv /uvx /bin/

RUN apt-get update && \
    apt-get install -y --no-install-recommends wget && \
    rm -rf /var/lib/apt/lists/*

# Install FoundationDB client library (needed by the Python bindings at runtime)
ARG FDB_VERSION=7.3.69
RUN ARCH=$(dpkg --print-architecture) && \
    if [ "$ARCH" = "arm64" ]; then ARCH="aarch64"; fi && \
    wget -qO /tmp/fdb-clients.deb \
    "https://github.com/apple/foundationdb/releases/download/${FDB_VERSION}/foundationdb-clients_${FDB_VERSION}-1_${ARCH}.deb" && \
    dpkg -i /tmp/fdb-clients.deb && \
    rm /tmp/fdb-clients.deb

WORKDIR /app

# Install matyan-backend from PyPI.
RUN uv pip install --system --no-cache "matyan-backend==${IMAGE_VERSION}"

CMD ["matyan-backend", "start", "--host", "0.0.0.0", "--port", "53800"]
